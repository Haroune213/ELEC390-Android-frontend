<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="560dp"
    android:layout_gravity="center"
    android:background="@drawable/dialog_rounded_bg"
    android:padding="5dp">

    <TextView
        android:id="@+id/textView4"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Edit User Preferences"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/cancelPoolInfo_btn"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="15dp"
        android:backgroundTint="#CACACA"
        android:text="@string/cancel"
        android:textColor="#303A38"
        android:textStyle="bold" />

    <Button
        android:id="@+id/savePoolInfo_btn"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="15dp"
        android:backgroundTint="#76CCD7"
        android:text="@string/save"
        android:textColor="#303A38"
        android:textStyle="bold" />

    <Button
        android:id="@+id/reset_defaults_btn"
        android:layout_width="160dp"
        android:layout_height="36dp"
        android:layout_above="@id/cancelPoolInfo_btn"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#B0E0E6"
        android:text="Set to default"
        android:textColor="#303A38"
        android:textSize="12sp"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/dialog_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/textView4"
        android:layout_above="@id/reset_defaults_btn"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="5dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <!-- Temperature -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="20dp"
                android:text="Temperature:"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="max:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="120dp"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="min:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="122dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/textView1"/>

            <EditText
                android:id="@+id/editTextNumberDecimal"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="35dp"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editTextNumberDecimal1"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:inputType="numberDecimal"
                android:layout_below="@+id/editTextNumberDecimal"/>

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="45dp"
                android:background="?android:attr/listDivider"
                android:layout_below="@+id/textView" />

            <!-- Depth -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider"
                android:text="Depth:"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="max:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="120dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="min:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="122dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/textView4"/>

            <EditText
                android:id="@+id/editTextNumberDecimal2"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="5dp"
                android:layout_below="@+id/divider"
                android:layout_marginEnd="35dp"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editTextNumberDecimal3"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:layout_below="@+id/editTextNumberDecimal2"
                android:inputType="numberDecimal"/>

            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="45dp"
                android:background="?android:attr/listDivider"
                android:layout_below="@+id/textView3" />

            <!-- TDS -->
            <TextView
                android:id="@+id/textView6"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider1"
                android:text="TDS:"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="max:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="120dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider1"/>

            <TextView
                android:id="@+id/textView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="min:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="122dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/textView7"/>

            <EditText
                android:id="@+id/editTextNumberDecimal4"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_below="@+id/divider1"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editTextNumberDecimal5"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:layout_below="@+id/editTextNumberDecimal4"
                android:inputType="numberDecimal"/>

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="45dp"
                android:background="?android:attr/listDivider"
                android:layout_below="@+id/textView6" />

            <!-- pH -->
            <TextView
                android:id="@+id/textView9"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider2"
                android:text="pH:"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="max:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="120dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/divider2"/>

            <TextView
                android:id="@+id/textView11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="min:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="122dp"
                android:layout_marginTop="15dp"
                android:layout_below="@+id/textView10"/>

            <EditText
                android:id="@+id/editTextNumberDecimal6"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_below="@+id/divider2"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editTextNumberDecimal7"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:layout_below="@+id/editTextNumberDecimal6"
                android:inputType="numberDecimal"/>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>