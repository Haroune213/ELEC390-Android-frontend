<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="350dp"
    android:layout_height="500dp"
    android:layout_gravity="center"
    android:background="@drawable/dialog_rounded_bg"
    android:padding="5dp"
    tools:context=".View.editPoolInfoDialogFragment">

    <TextView
        android:id="@+id/textView4"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/edit_pool_informations"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/cancelPoolInfo_btn"
        android:layout_width="117dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="44dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#CACACA"
        android:textColor="#303A38"
        android:textStyle="bold"
        android:text="@string/cancel" />

    <Button
        android:id="@+id/savePoolInfo_btn"
        android:layout_width="117dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="44dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#76CCD7"
        android:textColor="#303A38"
        android:textStyle="bold"
        android:text="@string/save" />

    <ScrollView
        android:id="@+id/dialog_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/textView4"
        android:layout_above="@id/cancelPoolInfo_btn"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/textView"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_toStartOf="@+id/radioGroup"
                android:text="@string/pool_typee"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/radioGroup"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="30dp"
                android:layout_marginTop="20dp">

                <RadioButton
                    android:id="@+id/chlorine_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:checked="true"
                    android:text="@string/chlorine"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/salt_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:text="@string/salt"
                    android:textSize="16sp" />
            </RadioGroup>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/radioGroup"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="7dp"
                android:layout_toStartOf="@+id/editTextText2"
                android:text="@string/pool_dimension"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editTextText"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:layout_below="@id/radioGroup"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:layout_marginTop="10dp"
                android:autofillHints=""
                android:hint="@string/width"
                android:inputType="text"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/editTextText2"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:layout_below="@id/editTextText"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:autofillHints=""
                android:hint="@string/depth"
                android:inputType="text"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/editTextText3"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:layout_below="@id/editTextText2"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="35dp"
                android:autofillHints=""
                android:hint="@string/lenght"
                android:inputType="text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/editTextText3"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="55dp"
                android:layout_toStartOf="@+id/units_radioGroup"
                android:text="@string/unit"
                android:textSize="17sp" />

            <RadioGroup
                android:id="@+id/units_radioGroup"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/editTextText3"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="30dp"
                android:layout_marginTop="13dp">

                <RadioButton
                    android:id="@+id/feets_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:checked="true"
                    android:text="@string/feets_ft"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/meter_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:text="@string/meters_m"
                    android:textSize="16sp" />
            </RadioGroup>

            <TextView
                android:id="@+id/textView5"
                android:layout_width="130dp"
                android:layout_height="39dp"
                android:layout_below="@+id/units_radioGroup"
                android:layout_alignParentStart="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="-5dp"
                android:layout_toStartOf="@+id/units_radioGroup"
                android:text="@string/chlorine_type"
                android:textSize="17sp" />

            <RadioGroup
                android:id="@+id/ctype_radioGroup"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/units_radioGroup"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="30dp"
                android:layout_marginTop="13dp">

                <RadioButton
                    android:id="@+id/liquid_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:checked="true"
                    android:text="@string/liquid"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/grain_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:text="@string/grain"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/tablet_radiobtn"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:buttonTint="#76CCD7"
                    android:text="@string/tablet"
                    android:textSize="16sp" />
            </RadioGroup>


        </RelativeLayout>
    </ScrollView>

</RelativeLayout>