<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="460dp"
    android:layout_gravity="center"
    android:background="@drawable/dialog_rounded_bg"
    android:padding="5dp">

    <TextView
        android:id="@+id/textView4"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Edit Pool Information"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/cancelPoolInfo_btn"
        android:layout_width="117dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="44dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#CACACA"
        android:textColor="#303A38"
        android:textStyle="bold"
        android:text="Cancel" />

    <Button
        android:id="@+id/savePoolInfo_btn"
        android:layout_width="117dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="44dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#76CCD7"
        android:textColor="#303A38"
        android:textStyle="bold"
        android:text="Save" />

    <ScrollView
        android:id="@+id/dialog_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/textView4"
        android:layout_above="@id/cancelPoolInfo_btn"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Pool Type"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#303A38"/>

            <Spinner
                android:id="@+id/spinner_pool_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/card_unselected"
                android:paddingHorizontal="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="?android:attr/listDivider"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="Dimensions"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#303A38"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Width"
                    android:textSize="14sp"
                    android:textColor="#555555"/>

                <EditText
                    android:id="@+id/editTextText"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="e.g. 5"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Depth"
                    android:textSize="14sp"
                    android:textColor="#555555"/>

                <EditText
                    android:id="@+id/editTextText2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="e.g. 2"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Length"
                    android:textSize="14sp"
                    android:textColor="#555555"/>

                <EditText
                    android:id="@+id/editTextText3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="e.g. 10"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="?android:attr/listDivider"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Units"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#303A38"/>

            <Spinner
                android:id="@+id/spinner_units"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/card_unselected"
                android:paddingHorizontal="12dp"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>